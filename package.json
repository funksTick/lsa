{
  "name": "lsa-lead-poller-nodered",
  "version": "1.0.0",
  "description": "Polls Google Ads API for Local Services Ads leads (no webhook exists for LSA) and syncs to MongoDB + QuickBase. Compiled output is required from a Node-RED function node.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "debug": "node --inspect-brk -r ts-node/register src/debug.ts",
    "debug:run": "ts-node src/debug.ts"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.6.1",
    "google-ads-api": "^24.1.0",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
